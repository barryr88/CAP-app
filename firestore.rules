rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fix for Error fetching user data: Allow collection group queries on 'users'
    match /{path=**}/users/{userId} {
      allow read: if request.auth != null && (resource.data.uid == request.auth.uid || request.auth.uid == userId);
    }

    // A user can access documents in a company if their own user document exists in that company.
    match /companies/{company}/{document=**} {
      allow read, write: if request.auth != null && exists(/databases/$(database)/documents/companies/$(company)/users/$(request.auth.uid));
    }

    // Rules for the nested time_entries subcollection
    match /companies/{company}/users/{userId}/time_entries/{timeEntryId} {
        // Allow a user to read, create, update, and delete their own time entries.
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Additionally, allow Managers of the same company to read time entries.
        allow get, list: if request.auth != null &&
                    get(/databases/$(database)/documents/companies/$(company)/users/$(request.auth.uid)).data.role == 'Manager';
    }
  }
}